{
  "name": "typescript-project-boilerplate",
  "version": "0.0.1",
  "description": "Boilerplate TS project",
  "engines": {
    "node": "22.13.0"
  },
  "packageManager": "pnpm@10.3.0+sha512.ee592eda8815a8a293c206bb0917c4bb0ff274c50def7cbc17be05ec641fc2d1b02490ce660061356bd0d126a4d7eb2ec8830e6959fb8a447571c631d5a2442d",
  "scripts": {
    "format": "pnpm -r exec biome format --write .",
    "biome:fix": "pnpm -r exec biome check --write .",
    "biome:fix-unsafe": "pnpm -r exec biome check --write --unsafe .",
    "check:ci": "pnpm -r exec biome ci .",
    "check:types": "pnpm -r exec tsc --noEmit",
    "check": "pnpm run '/check:.*/'"
  },
  "devDependencies": {
    "@biomejs/biome": "1.9.4",
    "@total-typescript/tsconfig": "1.0.4"
  }
}
